# =============================================================================
# Pulse - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# This file is used by docker-compose and backend services.
# For the UI, see ui/.env.example
# =============================================================================

# ===== Required =====

# Google AI API key for the AI Engine (RCA, NLQ, Dashboard Generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===== Optional: Slack Integration =====

# Required only if using the Slack Pacer bot
# See: https://api.slack.com/apps
SLACK_BOT_TOKEN=           # xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=           # xapp-...

# ===== Infrastructure (defaults work for local Docker Compose) =====

ELASTICSEARCH_URL=http://localhost:9200
PROMETHEUS_URL=http://localhost:9090
