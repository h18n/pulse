# =============================================================================
# Pulse Alert Ingestion - Environment Variables
# =============================================================================
# Copy this file to .env before running the Alert Ingestion service.
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Elasticsearch URL for alert storage
ELASTICSEARCH_URL=http://localhost:9200

# Prometheus URL for querying metrics context
PROMETHEUS_URL=http://localhost:9090
