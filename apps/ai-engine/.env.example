# =============================================================================
# Pulse AI Engine - Environment Variables
# =============================================================================
# Copy this file to .env before running the AI Engine service.
# =============================================================================

# Server port (default: 3002)
PORT=3002

# Elasticsearch URL for alert storage
ELASTICSEARCH_URL=http://localhost:9200

# Prometheus URL for metrics queries
PROMETHEUS_URL=http://localhost:9090

# Google AI API key (REQUIRED for RCA, NLQ, Dashboard Generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
