# =============================================================================
# Pulse Slack Pacer Bot - Environment Variables
# =============================================================================
# Copy this file to .env before running the Slack Pacer service.
# See: https://api.slack.com/apps for creating a Slack app.
# =============================================================================

# Slack Bot Token (REQUIRED)
SLACK_BOT_TOKEN=           # xoxb-...

# Slack Signing Secret (REQUIRED)
SLACK_SIGNING_SECRET=

# Slack App-Level Token (REQUIRED for Socket Mode)
SLACK_APP_TOKEN=           # xapp-...

# AI Engine URL for querying analysis
AI_ENGINE_URL=http://localhost:3002
